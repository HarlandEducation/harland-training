<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Harland Education — Teacher Announcement | April 2026</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --gold: #C9A84C;
  --gold-lt: #E8C97A;
  --gold-pale: #F5EDDA;
  --obs: #0D0D0F;
  --obs2: #161618;
  --obs3: #1E1E21;
  --cream: #FAF7F2;
  --slate: rgba(250,247,242,0.55);
  --mist: rgba(250,247,242,0.28);
  --bd: rgba(255,255,255,0.07);
  --bd-gold: rgba(201,168,76,0.18);
  --grn: #2E9E68;
  --grn-pale: rgba(46,158,104,0.12);
  --red: #C43030;
  --red-pale: rgba(196,48,48,0.1);
  --amb: #E8A020;
  --amb-pale: rgba(232,160,32,0.1);
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  background: var(--obs);
  font-family: 'DM Sans', sans-serif;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28px 16px 52px;
  gap: 20px;
}

/* ── HEADER META ── */
.meta-row {
  display: flex;
  align-items: center;
  gap: 16px;
  font-size: 11.5px;
  color: var(--mist);
  letter-spacing: 0.06em;
}
.meta-row span { display: flex; align-items: center; gap: 5px; }
.meta-divider { width: 1px; height: 12px; background: rgba(255,255,255,0.1); }

/* ── CAROUSEL ── */
.carousel-wrap {
  position: relative;
  width: 100%;
  max-width: 520px;
}

.carousel {
  display: flex;
  overflow-x: scroll;
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
  gap: 14px;
  padding: 6px 4px 14px;
  scrollbar-width: none;
}
.carousel::-webkit-scrollbar { display: none; }

/* ── CARD ── */
.card {
  scroll-snap-align: center;
  flex-shrink: 0;
  width: 500px;
  background: var(--obs2);
  border-radius: 20px;
  border: 1px solid var(--bd-gold);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  box-shadow: 0 16px 56px rgba(0,0,0,0.6), 0 0 0 1px rgba(0,0,0,0.4);
}

@media (max-width: 540px) {
  .card { width: calc(100vw - 48px); }
  .carousel-wrap { max-width: 100%; }
}

.gold-bar {
  height: 3px;
  background: linear-gradient(90deg, transparent 0%, var(--gold) 25%, var(--gold-lt) 50%, var(--gold) 75%, transparent 100%);
  flex-shrink: 0;
}

/* ── CARD HEADER ── */
.card-header {
  background: linear-gradient(150deg, #1C1A10 0%, var(--obs) 100%);
  padding: 18px 24px 14px;
  border-bottom: 1px solid var(--bd-gold);
  flex-shrink: 0;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
}

.header-left {}
.brand {
  font-family: 'Cormorant Garamond', serif;
  font-size: 20px;
  font-weight: 600;
  color: var(--gold);
  letter-spacing: 0.04em;
  line-height: 1;
  margin-bottom: 3px;
}
.brand-sub {
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: rgba(201,168,76,0.4);
}

.header-right { text-align: right; flex-shrink: 0; }
.send-date {
  font-size: 11px;
  color: var(--mist);
  letter-spacing: 0.05em;
  margin-bottom: 5px;
}
.read-time {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-size: 10.5px;
  color: rgba(201,168,76,0.5);
  background: rgba(201,168,76,0.07);
  border: 1px solid rgba(201,168,76,0.15);
  border-radius: 20px;
  padding: 3px 9px;
}

/* Section tag */
.section-tag {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 9.5px;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  border-radius: 20px;
  padding: 3px 10px 3px 8px;
}
.tag-action { color: var(--amb); background: var(--amb-pale); border: 1px solid rgba(232,160,32,0.28); }
.tag-info   { color: var(--gold); background: rgba(201,168,76,0.09); border: 1px solid rgba(201,168,76,0.2); }
.tag-social { color: #A89FE8; background: rgba(168,159,232,0.1); border: 1px solid rgba(168,159,232,0.22); }
.tag-urgent { color: #E88080; background: var(--red-pale); border: 1px solid rgba(196,48,48,0.28); }
.tag-dot { width: 4px; height: 4px; border-radius: 50%; background: currentColor; flex-shrink: 0; }

.card-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 10px;
  margin-top: 10px;
}
.card-icon-title { display: flex; align-items: center; gap: 10px; }
.card-icon { font-size: 22px; line-height: 1; flex-shrink: 0; }
.card-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 21px;
  font-weight: 600;
  color: var(--cream);
  letter-spacing: 0.01em;
  line-height: 1.2;
}

/* ── CARD BODY ── */
.card-body {
  padding: 18px 24px 20px;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.body-text {
  font-size: 14.5px;
  line-height: 1.72;
  color: var(--slate);
}
.body-text strong { color: var(--cream); font-weight: 500; }

/* CTA strip */
.cta-strip {
  padding: 10px 14px;
  background: rgba(201,168,76,0.06);
  border-left: 2px solid var(--gold);
  border-radius: 0 6px 6px 0;
  font-size: 13.5px;
  font-weight: 500;
  color: var(--gold-lt);
  line-height: 1.55;
}

/* Detail box */
.detail-box {
  background: rgba(201,168,76,0.05);
  border: 1px solid var(--bd-gold);
  border-radius: 10px;
  padding: 12px 16px;
  display: flex;
  flex-direction: column;
  gap: 9px;
}
.detail-row {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 14px;
  color: var(--slate);
}
.detail-row strong { color: var(--cream); font-weight: 500; }
.detail-icon { width: 18px; text-align: center; flex-shrink: 0; font-size: 14px; }

/* RSVP */
.rsvp-options { display: flex; flex-direction: column; gap: 8px; }
.rsvp-row {
  display: flex;
  align-items: center;
  gap: 12px;
  background: rgba(255,255,255,0.03);
  border: 1px solid var(--bd);
  border-radius: 10px;
  padding: 11px 14px;
  cursor: pointer;
  transition: background 0.15s, border-color 0.15s;
}
.rsvp-row:hover { background: rgba(255,255,255,0.05); }
.rsvp-row.selected-yes { border-color: rgba(46,158,104,0.5); background: var(--grn-pale); }
.rsvp-row.selected-no  { border-color: rgba(196,48,48,0.4); background: var(--red-pale); }
.rsvp-emoji { font-size: 18px; flex-shrink: 0; }
.rsvp-label { font-size: 14px; font-weight: 500; color: var(--cream); flex: 1; }
.rsvp-badge {
  font-size: 11.5px;
  font-weight: 600;
  padding: 4px 12px;
  border-radius: 20px;
  white-space: nowrap;
}
.badge-yes { background: rgba(46,158,104,0.15); border: 1px solid rgba(46,158,104,0.3); color: #6DD896; }
.badge-no  { background: var(--red-pale); border: 1px solid rgba(196,48,48,0.3); color: #E89090; }

/* ACK */
.ack-box {
  background: rgba(0,0,0,0.25);
  border: 1px solid var(--bd-gold);
  border-radius: 10px;
  padding: 14px 16px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.ack-text {
  font-size: 14px;
  color: var(--slate);
  line-height: 1.6;
}
.ack-text strong { color: var(--cream); }
.ack-btn {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  font-family: 'DM Sans', sans-serif;
  font-size: 13px;
  font-weight: 600;
  color: var(--obs);
  background: linear-gradient(135deg, var(--gold-lt), var(--gold));
  border: none;
  border-radius: 20px;
  padding: 8px 18px;
  cursor: pointer;
  transition: opacity 0.15s;
  align-self: flex-start;
}
.ack-btn:hover { opacity: 0.88; }
.ack-btn.done { background: var(--grn-pale); color: var(--grn); border: 1px solid rgba(46,158,104,0.3); }
.ack-deadline { font-size: 11px; color: var(--mist); margin-top: 2px; }

/* names box */
.names-box {
  background: rgba(201,168,76,0.05);
  border: 1px solid var(--bd-gold);
  border-radius: 10px;
  padding: 12px 16px;
}
.names-list { font-size: 14.5px; color: var(--cream); font-weight: 500; line-height: 2; }
.names-note { font-size: 12px; color: var(--mist); margin-top: 5px; }

/* Zoom banner (compact) */
.zoom-banner {
  display: flex;
  align-items: center;
  gap: 12px;
  background: rgba(59,108,198,0.1);
  border: 1px solid rgba(59,108,198,0.25);
  border-radius: 10px;
  padding: 11px 14px;
}
.zoom-icon { font-size: 20px; flex-shrink: 0; }
.zoom-text { flex: 1; }
.zoom-title { font-size: 13px; font-weight: 500; color: var(--cream); margin-bottom: 2px; }
.zoom-sub { font-size: 11.5px; color: var(--slate); }
.zoom-badge {
  font-size: 10.5px;
  font-weight: 600;
  color: #7AAFFF;
  background: rgba(59,108,198,0.15);
  border: 1px solid rgba(59,108,198,0.3);
  border-radius: 20px;
  padding: 3px 10px;
  white-space: nowrap;
}

/* Quick actions strip (cover card) */
.quick-actions {
  background: rgba(0,0,0,0.3);
  border: 1px solid var(--bd-gold);
  border-radius: 10px;
  overflow: hidden;
}
.qa-header {
  padding: 9px 14px;
  font-size: 9.5px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--mist);
  border-bottom: 1px solid var(--bd-gold);
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.qa-count {
  font-size: 10px;
  font-weight: 600;
  color: var(--amb);
  background: var(--amb-pale);
  border: 1px solid rgba(232,160,32,0.28);
  border-radius: 20px;
  padding: 1px 8px;
}
.qa-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 14px;
  border-bottom: 1px solid rgba(255,255,255,0.04);
  cursor: pointer;
  transition: background 0.15s;
}
.qa-item:last-child { border-bottom: none; }
.qa-item:hover { background: rgba(255,255,255,0.03); }
.qa-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
.dot-action { background: var(--amb); }
.dot-info   { background: var(--gold); opacity: 0.5; }
.dot-social { background: #A89FE8; opacity: 0.7; }
.qa-label { font-size: 13px; color: var(--slate); flex: 1; }
.qa-label strong { color: var(--cream); font-weight: 500; }
.qa-arrow { font-size: 11px; color: var(--mist); }

/* Cover items (swipe hint area) */
.cover-swipe-hint {
  font-size: 12px;
  color: var(--mist);
  text-align: center;
  letter-spacing: 0.04em;
}

/* ── CARD FOOTER ── */
.card-footer {
  padding: 0 24px 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-shrink: 0;
  margin-top: auto;
}
.card-counter {
  font-family: 'DM Mono', monospace;
  font-size: 10.5px;
  color: var(--mist);
  letter-spacing: 0.06em;
}
.dots {
  display: flex;
  gap: 6px;
  align-items: center;
}
.dot {
  width: 7px; height: 7px;
  border-radius: 50%;
  background: rgba(201,168,76,0.2);
  transition: background 0.2s, transform 0.2s, width 0.2s;
  cursor: pointer;
}
.dot.active {
  background: var(--gold);
  transform: scale(1.2);
  width: 18px;
  border-radius: 4px;
}

/* ── NAV BUTTONS ── */
.nav-row {
  display: flex;
  gap: 10px;
  align-items: center;
}
.nav-btn {
  font-family: 'DM Sans', sans-serif;
  font-size: 12.5px;
  font-weight: 600;
  letter-spacing: 0.06em;
  color: var(--obs);
  background: linear-gradient(135deg, var(--gold-lt), var(--gold));
  border: none;
  border-radius: 30px;
  padding: 9px 22px;
  cursor: pointer;
  transition: opacity 0.15s, transform 0.1s;
  box-shadow: 0 3px 14px rgba(201,168,76,0.28);
}
.nav-btn:hover { opacity: 0.85; transform: translateY(-1px); }
.nav-btn:disabled { opacity: 0.25; cursor: default; transform: none; box-shadow: none; }
.nav-btn.ghost {
  color: var(--gold);
  background: transparent;
  border: 1px solid rgba(201,168,76,0.5);
  box-shadow: none;
}
.nav-btn.ghost:hover { background: rgba(201,168,76,0.09); }

/* Toast */
.toast {
  position: fixed;
  bottom: 24px;
  left: 50%;
  transform: translateX(-50%) translateY(20px);
  background: var(--obs3);
  color: var(--cream);
  font-size: 13px;
  padding: 10px 20px;
  border-radius: 20px;
  border: 1px solid var(--bd-gold);
  box-shadow: 0 8px 24px rgba(0,0,0,0.4);
  opacity: 0;
  transition: all 0.25s;
  pointer-events: none;
  white-space: nowrap;
  z-index: 100;
}
.toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

/* Animations */
.card { animation: cardIn 0.4s ease both; }
@keyframes cardIn { from { opacity:0; transform:translateY(12px); } to { opacity:1; transform:translateY(0); } }

/* Dinner special banner */
.dinner-banner {
  display: flex;
  align-items: center;
  gap: 12px;
  background: linear-gradient(135deg, rgba(196,48,48,0.15) 0%, rgba(180,30,30,0.08) 100%);
  border: 1px solid rgba(196,48,48,0.4);
  border-radius: 10px;
  padding: 0;
  overflow: hidden;
  cursor: pointer;
}
.dinner-banner-main {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 14px;
  flex: 1;
}
.dinner-icon { font-size: 20px; flex-shrink: 0; }
.dinner-text { flex: 1; }
.dinner-title { font-size: 13.5px; font-weight: 600; color: #F09090; margin-bottom: 2px; }
.dinner-sub { font-size: 11.5px; color: var(--slate); }
.dinner-badge {
  font-size: 10.5px;
  font-weight: 600;
  color: #F08080;
  background: rgba(196,48,48,0.18);
  border: 1px solid rgba(196,48,48,0.35);
  border-radius: 20px;
  padding: 3px 10px;
  white-space: nowrap;
  margin-right: 14px;
}
.dinner-expand {
  display: none;
  border-top: 1px solid rgba(196,48,48,0.2);
  padding: 12px 14px;
  flex-direction: column;
  gap: 8px;
}
.dinner-expand.open { display: flex; }
.dinner-expand-row {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 13px;
  color: rgba(250,247,242,0.65);
}
.dinner-expand-row strong { color: var(--cream); font-weight: 500; }
.dinner-expand-row .detail-icon { width: 18px; text-align: center; flex-shrink: 0; }

/* Intro card special treatment */
.intro-body {
  padding: 28px 26px 24px;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 18px;
}
.intro-greeting {
  font-family: 'Cormorant Garamond', serif;
  font-size: 32px;
  font-weight: 500;
  color: var(--cream);
  line-height: 1.15;
  letter-spacing: 0.01em;
}
.intro-greeting em {
  font-style: italic;
  color: var(--gold);
}
.intro-text {
  font-size: 15px;
  line-height: 1.78;
  color: rgba(250,247,242,0.6);
}
.intro-text strong { color: var(--cream); font-weight: 500; }
.intro-sig {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-top: 4px;
  padding-top: 16px;
  border-top: 1px solid rgba(201,168,76,0.15);
}
.sig-mark {
  font-family: 'Cormorant Garamond', serif;
  font-size: 26px;
  color: rgba(201,168,76,0.4);
  line-height: 1;
}
.sig-text { font-size: 12px; color: var(--mist); }
.sig-name { font-size: 13px; font-weight: 500; color: var(--cream); margin-bottom: 1px; }

/* Teacher bio dropdown */
.teacher-row {
  cursor: pointer;
  transition: background 0.15s;
  border-radius: 6px;
  margin: 0 -4px;
  padding: 0 4px;
}
.teacher-row:hover { background: rgba(255,255,255,0.04); }
.teacher-row-header {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  padding: 9px 14px;
  border-bottom: 1px solid rgba(255,255,255,0.04);
  align-items: center;
}
.teacher-row-header:last-child { border-bottom: none; }
.t-name {
  font-size: 13px;
  font-weight: 500;
  color: var(--cream);
  display: flex;
  align-items: center;
  gap: 7px;
}
.t-chevron {
  font-size: 10px;
  color: var(--mist);
  transition: transform 0.2s;
  flex-shrink: 0;
}
.t-chevron.open { transform: rotate(180deg); color: var(--gold); }
.t-bio {
  display: none;
  padding: 10px 14px 14px;
  border-bottom: 1px solid rgba(255,255,255,0.06);
  background: rgba(0,0,0,0.2);
}
.t-bio.open { display: block; }
.t-bio-text {
  font-size: 12.5px;
  color: rgba(250,247,242,0.6);
  line-height: 1.72;
}
.t-bio-programmes {
  display: flex;
  flex-wrap: wrap;
  gap: 5px;
  margin-top: 9px;
}
.t-prog-pill {
  font-size: 10.5px;
  font-weight: 500;
  color: var(--gold);
  background: rgba(201,168,76,0.1);
  border: 1px solid rgba(201,168,76,0.22);
  border-radius: 20px;
  padding: 2px 10px;
}
.t-tap-hint {
  font-size: 10.5px;
  color: var(--mist);
  text-align: center;
  margin-top: 8px;
  letter-spacing: 0.03em;
}
</style>
</head>
<body>

<div class="meta-row">
  <span>📋 Teacher Announcement</span>
  <div class="meta-divider"></div>
  <span>April 2026</span>
  <div class="meta-divider"></div>
  <span>Harland Education</span>
</div>

<div class="carousel-wrap">
  <div class="carousel" id="carousel">

    <!-- ══ CARD 1: COVER ══ -->
    <div class="card">
      <div class="gold-bar"></div>
      <div class="card-header">
        <div class="header-left">
          <div class="brand">Harland Education</div>
          <div class="brand-sub">Teacher Announcement</div>
        </div>
        <div class="header-right">
          <div class="send-date">Sent 13 April 2026</div>
          <div class="read-time">&#9201; 7 cards &middot; ~3 min</div>
        </div>
      </div>
      <div class="card-body">

        <!-- Q1 Dinner — special red banner, expandable -->
        <div class="dinner-banner" id="dinner-toggle" onclick="toggleDinner()">
          <div style="width:100%">
            <div class="dinner-banner-main">
              <div class="dinner-icon">&#127863;</div>
              <div class="dinner-text">
                <div class="dinner-title">Q1 Teacher&rsquo;s Dinner &mdash; Saturday 25 April</div>
                <div class="dinner-sub">18:15 &middot; GB Brewery, Xinyi &middot; Tap for details &amp; RSVP</div>
              </div>
              <div class="dinner-badge" id="dinner-chevron">&#8964;</div>
            </div>
            <div class="dinner-expand" id="dinner-detail">
              <div class="dinner-expand-row"><span class="detail-icon">&#128197;</span><span><strong>Saturday 25 April 2026</strong> &middot; 18:15</span></div>
              <div class="dinner-expand-row"><span class="detail-icon">&#128205;</span><span><strong>GB Brewery</strong> &middot; No. 11 Songshou Road, 2F &middot; Xinyi District, Taipei</span></div>
              <div class="dinner-expand-row"><span class="detail-icon">&#127870;</span><span>Celebrate Q1 and welcome our new team members</span></div>
              <div class="dinner-expand-row" style="margin-top:2px">
                <span class="detail-icon">&#128172;</span>
                <span style="color:#F09090;font-weight:500;">RSVP via the LINE dinner invitation &mdash; YES or NO by <strong>20 April</strong></span>
              </div>
            </div>
          </div>
        </div>

        <!-- Zoom reminder -->
        <div class="zoom-banner">
          <div class="zoom-icon">&#128247;</div>
          <div class="zoom-text">
            <div class="zoom-title">Zoom &mdash; use Personal Meeting ID</div>
            <div class="zoom-sub">New Meeting &#8594; tick &ldquo;Use my Personal Meeting ID (PMI)&rdquo; before starting.</div>
          </div>
          <div class="zoom-badge">Reminder</div>
        </div>

        <!-- Quick actions -->
        <div class="quick-actions">
          <div class="qa-header">
